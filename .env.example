# Copia este archivo como .env y completa los valores
# NUNCA subas el .env al repositorio

# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_db
DB_USERNAME=
DB_PASSWORD=

# Servidor
SERVER_PORT=9000
ISSUER_URI=http://localhost:9000

# Cliente OAuth2 demo (desarrollo)
DEMO_CLIENT_ID=demo-client
DEMO_CLIENT_SECRET=

# Email — usar Mailtrap Sandbox en desarrollo (mailtrap.io)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@auth-service.com
